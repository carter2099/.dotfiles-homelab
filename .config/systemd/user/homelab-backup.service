[Unit]
Description=Homelab backup to Cloudflare R2
Wants=network-online.target
After=network-online.target
OnFailure=homelab-backup-notify.service

[Service]
Type=oneshot
WorkingDirectory=/home/carter/homelab-backup
EnvironmentFile=/home/carter/homelab-backup/.env
ExecStartPre=/home/carter/homelab-backup/pre-collect.sh
ExecStart=/home/carter/homelab-backup/homelab-backup run